{
    "name": "@kodira/omlox-client-typescript-angular",
    "version": "0.1.0",
    "description": "TypeScript Angular client for the OMLOX Hub API 2.0",
    "main": "index.js",
    "types": "index.d.ts",
    "keywords": [
        "omlox",
        "angular",
        "typescript"
    ],
    "author": "Kodira GmbH",
    "license": "MIT",
    "peerDependencies": {
        "@angular/common": ">=16.0.0",
        "@angular/core": ">=16.0.0"
    },
    "devDependencies": {
        "@angular/build": "^20.3.13",
        "@angular/cli": "^20.3.13",
        "@angular/compiler-cli": "^20.3.0",
        "@angular-devkit/build-angular": "^20.3.0",
        "typescript": "~5.9.2"
    },
    "dependencies": {
        "tslib": "^2.3.0"
    },
    "sideEffects": false,
    "scripts": {
        "build": "ng build",
        "publish": "rm -r dist/* && npm run build && cd dist && npm publish",
        "link": "rm -r dist/* && npm run build && cd dist && npm link"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/kodira/omlox-client-typescript-angular.git"
    },
    "bugs": {
        "url": "https://github.com/kodira/omlox-client-typescript-angular/issues"
    },
    "homepage": "https://github.com/kodira/omlox-client-typescript-angular#readme"
}

{
    "name": "@kodira/omlox-client-typescript-angular",
    "version": "0.2.3",
    "description": "TypeScript Angular client for the OMLOX Hub API 2.0",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "main": "index.js",
    "types": "index.d.ts",
    "keywords": [
        "omlox",
        "angular",
        "typescript"
    ],
    "author": "Kodira GmbH",
    "license": "MIT",
    "peerDependencies": {
        "@angular/common": ">=16.0.0",
        "@angular/core": ">=16.0.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^21.0.0",
        "@angular/build": "^21.0.0",
        "@angular/cli": "^21.0.0",
        "@angular/compiler-cli": "^21.0.0",
        "ng-packagr": "^21.0.0",
        "prettier": "^3.7.4",
        "typescript": "~5.9.2"
    },
    "dependencies": {
        "tslib": "^2.3.0"
    },
    "sideEffects": false,
    "scripts": {
        "build": "ng build",
        "publish": "rm -rf dist/* && npm run build && cd dist && npm publish --registry https://registry.npmjs.org/",
        "link": "rm -r dist/* && npm run build && cd dist && npm link",
        "format": "prettier -w ."
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kodira/omlox-client-typescript-angular.git"
    },
    "bugs": {
        "url": "https://github.com/kodira/omlox-client-typescript-angular/issues"
    },
    "homepage": "https://github.com/kodira/omlox-client-typescript-angular#readme"
}
